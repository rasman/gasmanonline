####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/gasmchn/bin || mkdir -p $(INSTALL_ROOT)/opt/gasmchn/bin
	$(QINSTALL) $(TARGET) $(INSTALL_ROOT)/opt/gasmchn/bin/$(TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) $(INSTALL_ROOT)/opt/gasmchn/bin/$(TARGET)
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/gasmchn/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

