####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/gasman_main/bin || mkdir -p $(INSTALL_ROOT)/opt/gasman_main/bin
	$(QINSTALL_PROGRAM) $(QMAKE_TARGET) $(INSTALL_ROOT)/opt/gasman_main/bin/$(QMAKE_TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) $(INSTALL_ROOT)/opt/gasman_main/bin/$(QMAKE_TARGET)
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/gasman_main/bin/ 


install_js_file: first FORCE
	@test -d $(INSTALL_ROOT)/opt/gasman_main/bin || mkdir -p $(INSTALL_ROOT)/opt/gasman_main/bin
	$(QINSTALL_PROGRAM) /home/elie/workspace/gasmanonlinev5/src/gasman_main/gasman.js $(INSTALL_ROOT)/opt/gasman_main/bin/gasman.js

uninstall_js_file: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/opt/gasman_main/bin/gasman.js
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/gasman_main/bin/ 


install: install_target install_js_file  FORCE

uninstall: uninstall_target uninstall_js_file  FORCE

FORCE:

