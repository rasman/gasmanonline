# Normalize all text files to LF in the repo; convert to native on checkout.
* text=auto eol=lf

# Explicit text files
*.cpp       text eol=lf
*.h         text eol=lf
*.hpp       text eol=lf
*.c         text eol=lf
*.pro       text eol=lf
*.pri       text eol=lf
*.qrc       text eol=lf
*.ui        text eol=lf
*.ts        text eol=lf
*.xsl       text eol=lf
*.xml       text eol=lf
*.html      text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.ini       text eol=lf
*.conf      text eol=lf
*.csv       text eol=lf
*.py        text eol=lf
*.R         text eol=lf
*.m         text eol=lf
*.sh        text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.yml       text eol=lf
*.xpm       text eol=lf
*.svg       text eol=lf
*.user      text eol=lf

# Binary files — never touch line endings
*.png       binary
*.pdf       binary
*.xlsx      binary
*.qm        binary
*.so        binary
*.o         binary
